generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuarios del panel admin
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// Autos en venta
model Auto {
  id          String   @id @default(cuid())
  titulo      String
  marca       String
  modelo      String
  año         Int
  precio      Decimal  @db.Decimal(12, 2)
  kilometros  Int
  color       String
  transmision String
  combustible String
  descripcion String   @db.Text
  imagenes    String[] // URLs de imágenes
  caracteristicas String[] // lista de características
  disponibles Boolean  @default(true)
  destacado   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contactos/leads del formulario
model Contacto {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  mensaje   String   @db.Text
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Configuraciones generales
model Configuracion {
  id    String @id @default("global")
  telefono String?
  email    String?
  direccion String?
  horario  String?
  updatedAt DateTime @updatedAt
}